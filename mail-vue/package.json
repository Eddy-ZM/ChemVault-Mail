{
  "name": "mail-vue",
  "private": true,
  "description": "ChemVault Mail web and Windows desktop client.",
  "author": "ChemVault",
  "license": "UNLICENSED",
  "version": "0.1.5",
  "type": "module",
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "vite --mode dev",
    "remote": "vite --mode remote",
    "build": "vite build --mode release",
    "desktop:dev": "node desktop/scripts/dev.mjs",
    "desktop:build": "vite build --mode desktop",
    "desktop:dist:win": "pnpm run desktop:build && node desktop/scripts/build-win-installer.mjs never && node desktop/scripts/archive-win-release.mjs",
    "desktop:publish:win": "pnpm run desktop:build && node desktop/scripts/build-win-installer.mjs always && node desktop/scripts/archive-win-release.mjs",
    "desktop:test:win": "node desktop/scripts/smoke-win.mjs",
    "desktop:verify-signature:win": "node desktop/scripts/verify-signature-win.mjs",
    "eo": "vite build --mode eo",
    "preview": "vite preview"
  },
  "dependencies": {
    "@iconify/vue": "^4.3.0",
    "@vueuse/components": "^14.1.0",
    "@vueuse/core": "^12.0.0",
    "axios": "1.15.2",
    "compressorjs": "^1.2.1",
    "date-time-format-timezone": "^1.0.22",
    "dayjs": "^1.11.13",
    "dexie": "^4.0.11",
    "echarts": "^5.6.0",
    "electron-updater": "^6.8.9",
    "element-plus": "^2.13.1",
    "lodash-es": "^4.17.21",
    "nprogress": "^0.2.0",
    "path": "^0.12.7",
    "pinia": "^3.0.2",
    "pinia-plugin-persistedstate": "^4.2.0",
    "vue": "^3.5.13",
    "vue-i18n": "^11.1.10",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "less": "^4.2.2",
    "sass": "^1.82.0",
    "terser": "^5.39.0",
    "unplugin-auto-import": "^19.3.0",
    "unplugin-vue-components": "^28.7.0",
    "vite": "7.1.5",
    "vite-plugin-pwa": "^1.0.3"
  }
}
