MAIL_DOMAIN=chemvault.science
MAILDIR_ROOT=/var/vmail
IMAP_HOST=imap.chemvault.science
SMTP_HOST=smtp.chemvault.science
SMTP_PORT=587
SMTP_DEV_PORT=2525
RESEND_API_KEY=your_resend_api_key_here
RESEND_WEBHOOK_SECRET=replace_with_resend_webhook_secret
INTERNAL_MAIL_GATEWAY_TOKEN=replace_with_secure_internal_token
MAIL_GATEWAY_URL=http://localhost:8789
MAIN_APP_INTERNAL_URL=http://localhost:8788
DOVECOT_USERS_FILE=/etc/dovecot/users
DAILY_SMTP_LIMIT=100
APP_PASSWORD_HASH_SECRET=replace_with_secure_app_password_hash_secret

# mail-gateway local development
MAIL_GATEWAY_HTTP_HOST=0.0.0.0
MAIL_GATEWAY_HTTP_PORT=8789
MAIL_GATEWAY_AUTH_STORE=./data/auth-store.json
MAIL_GATEWAY_AUDIT_LOG=./data/audit.log
MAIL_GATEWAY_METADATA_STORE=./data/mail-metadata.jsonl
SMTP_TLS_KEY_PATH=path_to_local_tls_key_if_used
SMTP_TLS_CERT_PATH=path_to_local_tls_cert_if_used
